digraph TcpCmdProcessorStateLifecycle {
    graph [
        rankdir=TB,
        compound=true,
        nodesep=0.55,
        ranksep=0.75,
        splines=line,
        newrank=true,
        pad=0.2,
        bgcolor="transparent"
    ];

    node [
        shape=box,
        style="rounded,filled",
        fillcolor="white",
        color="#64748b",
        fontname="Pretendard",
        fontsize=11,
        margin="0.14,0.09"
    ];

    edge [
        color="#475569",
        fontname="Pretendard",
        fontsize=10,
        arrowsize=0.7
    ];

    subgraph cluster_lifecycle {
        label="request / response lifecycle";
        style="rounded,filled";
        color="#94a3b8";
        fillcolor="#f8fafc";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        read_validate [label="JSON line\nread + validate"];
        register [label="in-flight 등록\n중복 / limit 검사"];
        submit [label="CmdRequest 생성\nCmdProcessor 제출"];
        processor [label="CmdProcessor 구현체\nEngine / REPL / Mock"];
        callback [label="response callback"];
        write_cleanup [label="JSON 응답 write\nin-flight 제거\nrequest/response release"];
    }

    subgraph cluster_server_state {
        label="TCPCmdProcessor state";
        style="rounded,filled";
        color="#93c5fd";
        fillcolor="#eff6ff";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        server_state [label="listen fd / port\nconnections\nclient counters\nprocessor pointer"];
    }

    subgraph cluster_connection_state {
        label="TCPConnection state";
        style="rounded,filled";
        color="#bae6fd";
        fillcolor="#f0f9ff";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        connection_state [label="client fd / client key\nin-flight ids\nwrite mutex\nref count"];
    }

    { rank=same; read_validate; register; }
    { rank=same; submit; processor; callback; }
    { rank=same; write_cleanup; }
    { rank=same; server_state; connection_state; }

    read_validate -> register -> submit -> processor;
    processor -> callback [style=dashed, label="완료"];
    callback -> write_cleanup;

    register -> server_state [style=dotted, arrowhead=none, constraint=false];
    register -> connection_state [style=dotted, arrowhead=none, constraint=false];
    write_cleanup -> server_state [style=dotted, arrowhead=none, constraint=false];
    write_cleanup -> connection_state [style=dotted, arrowhead=none, constraint=false];
}
