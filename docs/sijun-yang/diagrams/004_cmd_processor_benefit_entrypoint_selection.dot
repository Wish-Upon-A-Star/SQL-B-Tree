digraph CmdProcessorBenefitEntrypointSelection {
    graph [
        rankdir=LR,
        compound=true,
        nodesep=0.55,
        ranksep=0.75,
        splines=line,
        newrank=true,
        pad=0.2,
        bgcolor="transparent"
    ];

    node [
        shape=box,
        style="rounded,filled",
        fillcolor="white",
        color="#64748b",
        fontname="Pretendard",
        fontsize=11,
        margin="0.14,0.09"
    ];

    edge [
        color="#475569",
        fontname="Pretendard",
        fontsize=10,
        arrowsize=0.7
    ];

    subgraph cluster_entrypoints {
        label="빌드/실행 설정: 진입점 하나를 선택";
        style="rounded,filled";
        color="#cbd5e1";
        fillcolor="#f8fafc";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        file_entry [label="파일 실행\nSQL file"];
        repl_entry [label="REPL 입력\nconsole"];
        tcp_entry [label="TCP 입력\nJSONL"];
    }

    shared_contract [
        label="공통 요청 계약\n입력 -> CmdRequest\nsubmit + callback",
        fillcolor="#dbeafe",
        color="#60a5fa"
    ];

    subgraph cluster_processing {
        label="공통 처리 뒤쪽";
        style="rounded,filled";
        color="#bae6fd";
        fillcolor="#f0f9ff";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        impl [
            label="선택된 처리 구현체\nEngine / REPL / Mock",
            fillcolor="white",
            color="#7dd3fc"
        ];

        db [
            label="DB BlackBox\nSQL 실행",
            fillcolor="#ffffff",
            color="#cbd5e1"
        ];

        response [
            label="외부 응답 형식\nconsole / TCP / test",
            fillcolor="#f8fafc",
            color="#cbd5e1"
        ];
    }

    { rank=same; file_entry; repl_entry; tcp_entry; }
    { rank=same; db; response; }

    file_entry -> shared_contract;
    repl_entry -> shared_contract;
    tcp_entry -> shared_contract;

    shared_contract -> impl;
    impl -> db [label="SQL"];
    impl -> response [style=dashed, label="callback"];
}
