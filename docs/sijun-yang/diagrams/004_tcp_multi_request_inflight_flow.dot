digraph TcpMultiRequestInflightFlow {
    graph [
        rankdir=TB,
        compound=true,
        nodesep=0.55,
        ranksep=0.8,
        splines=line,
        newrank=true,
        pad=0.2,
        bgcolor="transparent"
    ];

    node [
        shape=box,
        style="rounded,filled",
        fillcolor="white",
        color="#64748b",
        fontname="Pretendard",
        fontsize=11,
        margin="0.14,0.09"
    ];

    edge [
        color="#475569",
        fontname="Pretendard",
        fontsize=10,
        arrowsize=0.7
    ];

    subgraph cluster_r1 {
        label="r1: 느린 요청";
        style="rounded,filled";
        color="#cbd5e1";
        fillcolor="#f8fafc";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        r1_start [label="client send r1\nTCP register r1"];
        r1_proc [label="CmdProcessor\nr1 처리 중"];
        r1_cb [label="callback r1\n나중"];
        r1_done [label="TCP write r1\nclient receive r1\nin-flight []"];
    }

    subgraph cluster_r2 {
        label="r2: 빠른 요청";
        style="rounded,filled";
        color="#93c5fd";
        fillcolor="#eff6ff";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        r2_start [label="client send r2\nTCP register r2\nin-flight [r2, r1]"];
        r2_proc [label="CmdProcessor\nr2 처리"];
        r2_cb [label="callback r2\n먼저"];
        r2_done [label="TCP write r2\nclient receive r2\nin-flight [r1]"];
    }

    note [label="응답 순서는 완료 순서\n클라이언트는 id로 매칭", fillcolor="#fefce8", color="#facc15"];

    { rank=same; r1_start; r1_proc; r1_cb; r1_done; }
    { rank=same; r2_start; r2_proc; r2_cb; r2_done; note; }

    r1_start -> r1_proc -> r1_cb -> r1_done;
    r2_start -> r2_proc -> r2_cb -> r2_done;

    r1_start -> r2_start [style=dotted, arrowhead=none, label="같은 connection"];
    r2_cb -> r1_cb [style=dotted, arrowhead=none, label="r2가 먼저 완료"];
    note -> r2_done [style=dashed, constraint=false];
    note -> r1_done [style=dashed, constraint=false];
}
