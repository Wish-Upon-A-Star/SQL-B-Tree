digraph CmdProcessorDICoreOnly {
    graph [
        rankdir=LR,
        compound=true,
        nodesep=0.35,
        ranksep=0.7,
        splines=line,
        newrank=true,
        pad=0.2,
        bgcolor="transparent"
    ];

    node [
        shape=box,
        style="rounded,filled",
        fillcolor="white",
        color="#64748b",
        fontname="Pretendard",
        fontsize=11,
        margin="0.14,0.09"
    ];

    edge [
        color="#475569",
        fontname="Pretendard",
        fontsize=10,
        arrowsize=0.7
    ];

    subgraph cluster_impl {
        label="입출력 구현체";
        style="rounded,filled";
        color="#cbd5e1";
        fillcolor="#f8fafc";
        fontname="Pretendard";
        fontsize=13;
        margin=14;

        impl_slot [
            label="아직 선택되지 않음\n입출력 관리 없음",
            style="rounded,dashed,filled",
            fillcolor="#ffffff",
            color="#cbd5e1"
        ];
    }

    subgraph cluster_core {
        label="코어";
        style="rounded,filled";
        color="#bae6fd";
        fillcolor="#f0f9ff";
        fontname="Pretendard";
        fontsize=13;
        margin=14;

        cmd_processor [
            label="CmdProcessor\n요청 처리 정책",
            fillcolor="#ffffff"
        ];

        db [
            label="DB 실행\nBlackBox",
            fillcolor="#ffffff",
            color="#cbd5e1"
        ];
    }

    cmd_contract [
        label="CmdRequest / CmdResponse",
        fillcolor="#dbeafe",
        color="#60a5fa",
        margin="0.08,0.04"
    ];

    impl_slot -> cmd_contract [
        style=dashed,
        ltail=cluster_impl,
        arrowhead=none,
        minlen=2,
        weight=10
    ];
    cmd_contract -> cmd_processor [
        style=dashed,
        lhead=cluster_core,
        minlen=2,
        weight=10
    ];
    cmd_processor -> db [label="DB 의존", fontsize=9, minlen=1];
}
