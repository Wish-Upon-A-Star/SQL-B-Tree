digraph CmdProcessorDICoreOnly {
    graph [
        rankdir=TB,
        compound=true,
        nodesep=0.55,
        ranksep=0.65,
        splines=line,
        newrank=true,
        pad=0.2,
        bgcolor="transparent"
    ];

    node [
        shape=box,
        style="rounded,filled",
        fillcolor="white",
        color="#64748b",
        fontname="Pretendard",
        fontsize=11,
        margin="0.14,0.09"
    ];

    edge [
        color="#475569",
        fontname="Pretendard",
        fontsize=10,
        arrowsize=0.7
    ];

    placeholder [
        label="진입점 구현체 자리\n아직 주입되지 않음",
        style="rounded,dashed,filled",
        fillcolor="#f8fafc",
        color="#cbd5e1"
    ];

    subgraph cluster_core {
        label="코어 구현체";
        style="rounded,filled";
        color="#93c5fd";
        fillcolor="#eff6ff";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        main_core [
            label="main / request core\n공통 요청 처리 흐름"
        ];

        contract [
            label="CmdProcessor 계약\n요청 제출 + 응답 수신",
            fillcolor="#dbeafe",
            color="#60a5fa"
        ];

        db [
            label="DB BlackBox\nSQL 실행",
            fillcolor="#ffffff",
            color="#cbd5e1"
        ];
    }

    output [
        label="외부 출력 없음\n사용자 접점 없음",
        fillcolor="#f8fafc",
        color="#cbd5e1"
    ];

    { rank=same; main_core; contract; }
    { rank=same; db; output; }

    placeholder -> main_core [style=dashed, label="DI slot"];
    main_core -> contract -> db;
    contract -> output [style=dashed, label="response"];
}
