digraph CmdProcessorBenefitAddRequests {
    graph [
        rankdir=TB,
        compound=true,
        nodesep=0.55,
        ranksep=0.7,
        splines=line,
        newrank=true,
        pad=0.2,
        bgcolor="transparent"
    ];

    node [
        shape=box,
        style="rounded,filled",
        fillcolor="white",
        color="#64748b",
        fontname="Pretendard",
        fontsize=11,
        margin="0.14,0.09"
    ];

    edge [
        color="#475569",
        fontname="Pretendard",
        fontsize=10,
        arrowsize=0.7
    ];

    subgraph cluster_requests {
        label="요청 종류";
        style="rounded,filled";
        color="#cbd5e1";
        fillcolor="#f8fafc";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        ping [label="ping"];
        sql [label="sql"];
        close [label="close"];
        new_request [
            label="새 요청\n예: stats",
            fillcolor="#ecfdf5",
            color="#86efac"
        ];
    }

    mapper [
        label="요청 매핑\nop -> CmdRequest",
        fillcolor="#eff6ff",
        color="#93c5fd"
    ];

    core [
        label="공통 처리 코어\nsubmit / callback / release",
        fillcolor="#dbeafe",
        color="#60a5fa"
    ];

    subgraph cluster_unchanged {
        label="재사용되는 뒤쪽 흐름";
        style="rounded,filled";
        color="#bae6fd";
        fillcolor="#f0f9ff";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        processor [
            label="CmdProcessor 구현체\n필요한 처리만 추가",
            fillcolor="white",
            color="#7dd3fc"
        ];

        db [
            label="DB BlackBox",
            fillcolor="#ffffff",
            color="#cbd5e1"
        ];

        response [
            label="동일한 응답 경로",
            fillcolor="#f8fafc",
            color="#cbd5e1"
        ];
    }

    { rank=same; ping; sql; close; new_request; }
    { rank=same; mapper; core; }
    { rank=same; processor; db; response; }

    ping -> mapper;
    sql -> mapper;
    close -> mapper;
    new_request -> mapper [label="요청만 추가"];

    mapper -> core -> processor -> db;
    db -> response [style=dashed, label="callback"];
}
