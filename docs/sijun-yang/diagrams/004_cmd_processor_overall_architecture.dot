digraph CmdProcessorOverallArchitecture {
    graph [
        rankdir=LR,
        compound=true,
        nodesep=0.55,
        ranksep=0.85,
        splines=line,
        newrank=true,
        pad=0.2,
        bgcolor="transparent"
    ];

    node [
        shape=box,
        style="rounded,filled",
        fillcolor="white",
        color="#64748b",
        fontname="Pretendard",
        fontsize=11,
        margin="0.14,0.09"
    ];

    edge [
        color="#475569",
        fontname="Pretendard",
        fontsize=10,
        arrowsize=0.7
    ];

    subgraph cluster_frontends {
        label="외부 진입점";
        style="rounded,filled";
        color="#cbd5e1";
        fillcolor="#f8fafc";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        frontends [label="TCP / console / tests\n외부 요청과 응답"];
    }

    subgraph cluster_contract {
        label="CmdProcessor 공통 계약";
        style="rounded,filled";
        color="#93c5fd";
        fillcolor="#eff6ff";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        request [label="CmdRequest"];
        api [label="CmdProcessor interface\nacquire / submit / release"];
        response [label="CmdResponse"];
    }

    subgraph cluster_impls {
        label="CmdProcessor 구현체";
        style="rounded,filled";
        color="#bae6fd";
        fillcolor="#f0f9ff";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        engine [label="EngineCmdProcessor\nqueue + worker model"];
        repl [label="REPLCmdProcessor\nsync model"];
        mock [label="MockCmdProcessor\ntest model"];
    }

    subgraph cluster_db {
        label="DB 실행 계층";
        style="rounded,filled";
        color="#cbd5e1";
        fillcolor="#ffffff";
        fontname="Pretendard";
        fontsize=13;
        margin=18;

        db_black_box [label="DB BlackBox"];
    }

    { rank=same; request; api; response; }
    { rank=same; engine; repl; mock; }

    frontends -> request [label="요청", weight=10];

    request -> api [label="요청 제출", weight=10];
    api -> engine [weight=10];
    api -> repl [weight=10];
    api -> mock [weight=10];

    engine -> db_black_box [label="SQL 처리", weight=10];
    repl -> db_black_box [label="SQL 처리", weight=10];

    engine -> response [style=dashed, constraint=false];
    repl -> response [style=dashed, constraint=false];
    mock -> response [style=dashed, constraint=false];

    response -> frontends [style=dashed, label="응답", constraint=false];
}
